# BODR Image Prompt local configuration
# Copy to .env and edit if you want non-default local paths or ports.

# Where your private SQLite database and image files live.
# This directory is intentionally ignored by git when it is ./library.
IMAGE_PROMPT_LIBRARY_PATH=./library

# Backend API / single-service local app address.
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Vite development server port used by scripts/dev.sh.
FRONTEND_PORT=5177

# Where backup archives are written by scripts/backup.sh.
BACKUP_DIR=./backups

# ── 2026-07-11 BIP auth/RBAC ─────────────────────────────────────────────────
# Initial admin (主人). 只在第一次启动且无 admin 时生效. 已有 admin 则忽略.
INITIAL_ADMIN_EMAIL=admin@tooyang.top
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-me-strong-password
# Optional
INITIAL_ADMIN_DISPLAY_NAME=Admin

# JWT signing secret. 留空则系统启动时自动生成一次性 secret 并落 ~/.BODR-Image-Prompt/jwt_secret.
# 生产环境强烈建议显式设置 (openssl rand -hex 32).
JWT_SECRET=

# Allow anonymous read access. 默认 false (全站强制登录). 调试时可设 true 临时跳过 auth.
ALLOW_ANONYMOUS_READ=false

# Cookie Secure flag. auto (默认: BACKEND_HOST 不是 127.0.0.1/localhost 时开), true (强制开), false (强制关).
AUTH_COOKIE_SECURE=auto
